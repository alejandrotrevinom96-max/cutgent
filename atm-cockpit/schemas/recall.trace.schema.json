{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "recall.trace/1",
  "title": "recall.trace/1 — honest seed->1-hop traversal",
  "type": "object",
  "required": ["schema", "seeds", "expanded", "edges", "steps", "answer_sources"],
  "additionalProperties": true,
  "properties": {
    "schema": { "const": "recall.trace/1" },
    "tier": { "type": ["string", "null"] },
    "seeds": { "type": "array", "items": { "type": "string" } },
    "expanded": { "type": "array", "items": { "type": "string" } },
    "edges": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["src", "dst", "type"],
        "properties": {
          "src": { "type": "string" },
          "dst": { "type": "string" },
          "type": { "type": "string" }
        }
      }
    },
    "steps": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["kind", "node"],
        "properties": {
          "kind": { "enum": ["seed", "expand"] },
          "node": { "type": "string" },
          "edge": { "type": ["integer", "null"] }
        }
      }
    },
    "answer_sources": { "type": "array", "items": { "type": "string" } }
  }
}
