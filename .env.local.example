# Cutgent — variables de entorno
# Copia este archivo a .env.local y rellena tus claves. (.env.local está en .gitignore)

# Búsqueda de assets de stock (Fase 1). Claves GRATUITAS:
#  - Pexels:  https://www.pexels.com/api/  → "Your API Key"
#  - Pixabay: https://pixabay.com/api/docs/ → tu API key aparece logueado
PEXELS_API_KEY=
PIXABAY_API_KEY=

# URL de la app para el servidor MCP (por defecto http://localhost:3000)
CUTGENT_URL=http://localhost:3000
