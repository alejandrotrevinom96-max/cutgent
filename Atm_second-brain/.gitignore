# Derived/index artifacts — rebuildable from the markdown source of truth.
# The vault (markdown + git) is canonical; never commit the derived index.
*.db
*.db-wal
*.db-shm
*.sqlite
*.sqlite3
.atm/
selftest/.cache/

# Python
__pycache__/
*.py[cod]
.venv/
venv/

# OS / editor cruft
.DS_Store
.trash/
*.tmp
*.swp

# Obsidian — commit the declarative config (app/core-plugins/templates/daily-notes),
# ignore per-machine state and user-installed third-party plugin binaries.
.obsidian/workspace*.json
.obsidian/workspaces.json
.obsidian/cache
.obsidian/plugins/
.obsidian/community-plugins.json
